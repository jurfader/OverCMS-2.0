# Application
web/app/plugins/*
!web/app/plugins/.gitkeep
# Ignore Composer-installed mu-plugin directories; single-file mu-plugins are tracked intentionally
web/app/mu-plugins/*/
# But always track our own core
!web/app/mu-plugins/overcms-core/
# React build artifact (regenerated by `npm run build`)
web/app/mu-plugins/overcms-core/panel/dist/
web/app/themes/twentytwentyfive/

# React panel build artifacts
overcms-panel/node_modules/
overcms-panel/dist/
overcms-panel/*.tsbuildinfo
overcms-panel/vite.config.js
overcms-panel/vite.config.d.ts

# Release artifacts (uploadowane do GitHub Releases osobno)
overcms-*.zip
overcms-*.zip.sha256
overcms-1.0.0/

# macOS
.DS_Store
web/app/upgrade
web/app/uploads/*
!web/app/uploads/.gitkeep
web/app/cache/*

# WordPress
web/wp
web/.htaccess

# Logs
*.log

# Dotenv
.env
.env.*
!.env.example

# Composer
/vendor
auth.json

# PHPUnit/Pest
phpunit.xml
.phpunit.result.cache
.phpunit.cache

# WP-CLI
wp-cli.local.yml
